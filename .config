#
# Automatically generated file; DO NOT EDIT.
# ImmortalWrt Configuration
#
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y

# 目标架构：ramips mt7621 K2P
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# 编译基础
CONFIG_CCACHE=y
CONFIG_EXTERNAL_CCACHE=y
CONFIG_BUILD_PATENTED=y
CONFIG_USE_GLIBC=y

# 基础系统
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-network=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_uci=y

# USB 核心（必须）
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# 文件系统与挂载（必须）
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# NTFS 读写（正确组合：只留 ntfs-3g，禁用 kmod-fs-ntfs）
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_kmod-fuse=y
# CONFIG_PACKAGE_kmod-fs-ntfs is NOT set

# 网络驱动（K2P 网卡/无线）
CONFIG_PACKAGE_kmod-ethernet=y
CONFIG_PACKAGE_kmod-mt7530=y
CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_wpa-supplicant=y

# 常用工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_tcpdump=y

# 关闭无用冲突项（关键）
# CONFIG_PACKAGE_kmod-fs-ntfs is NOT set
CONFIG_PACKAGE_kmod-fs-hfs=n
CONFIG_PACKAGE_kmod-fs-hfsplus=n
CONFIG_PACKAGE_kmod-fs-reiserfs=n
CONFIG_PACKAGE_kmod-fs-xfs=n

###########################################################
# 【5】无用/多余/冲突项 —— 已帮你剔除   测试是否可用
###########################################################
# 以下你原来写的都可以删除，无意义、重复、K2P 不支持
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
