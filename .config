# ========================== 基础设置 ==========================
CONFIG_TARGET_ramips=y                             # 目标平台：联发科 RAMIPS 架构
CONFIG_TARGET_ramips_mt7621=y                      # 子架构：MT7621 双核 MIPS 芯片（K2P 主控）
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y   # 具体设备：斐讯 K2P（匹配 GPIO/分区/无线校准）
CONFIG_TARGET_ROOTFS_PARTSIZE=32128                # 根分区 32MB（适配硬改 32M 闪存，确保 overlay 空间）

# ====================== USB 核心支持（必须） ======================
CONFIG_USB_SUPPORT=y                               # USB 子系统总开关
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y                 # XHCI 主控制器驱动（USB 3.0 标准）
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # 联发科 XHCI 专用驱动（MT7621 USB3 优化）
CONFIG_PACKAGE_kmod-usb-core=y                     # USB 核心驱动（所有 USB 设备基础依赖）
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0 驱动（K2P 原生接口必需）
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0 驱动（硬改加装 USB3 接口必需）
CONFIG_PACKAGE_kmod-usb-storage=y                  # USB 存储驱动（U盘/移动硬盘）
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # UAS 高速协议（USB 3.0 硬盘提速 30%~50%）
CONFIG_PACKAGE_block-mount=y                       # 块设备挂载工具（自动挂载/卸载）

# ====================== ksmbd服务（替代samba4） ======================
CONFIG_PACKAGE_kmod-fs-ksmbd=y                     # ksmbd 内核模块（内核态 SMB 服务器，低内存高性能）
CONFIG_PACKAGE_ksmbd-server=y                      # ksmbd 服务程序（用户态组件，认证/配置）
CONFIG_PACKAGE_ksmbd-utils=y                       # ksmbd 管理工具（ksmbd.adduser 等）
CONFIG_PACKAGE_luci-app-ksmbd=y                    # ksmbd LuCI 网页配置界面
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y             # 简体中文语言包

# ============= 文件系统支持（EXT4 + NTFS读写 + exFAT + UTF-8） =============
CONFIG_PACKAGE_kmod-fs-ext4=y                      # EXT4 文件系统（Linux 原生，读写性能最佳）
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE 内核框架（ntfs-3g 依赖）
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS 完整读写驱动（替代内核态 ntfs，稳定可靠）
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF-8 字符集（解决中文文件名乱码）
CONFIG_PACKAGE_kmod-lib-crc16=y                    # CRC16 校验库（USB/文件系统/硬件驱动基础依赖）

# ======================= 系统基础 + 网页管理 =======================
CONFIG_PACKAGE_kmod-reboot=y                       # 软重启修复（解决 K2P reboot 失效问题）

# ======================== 防火墙内核模块 ========================
CONFIG_PACKAGE_kmod-ipt-core=y                     # iptables 核心框架（Netfilter 基础表）
CONFIG_PACKAGE_kmod-ipt-conntrack=y                # 连接跟踪（状态防火墙/NAT 老化）
CONFIG_PACKAGE_kmod-ipt-nat=y                      # NAT 模块（SNAT/DNAT，上网/端口映射）
CONFIG_PACKAGE_kmod-nft-compat=y                   # nftables 兼容层（运行旧 iptables 规则）
CONFIG_PACKAGE_iptables-nft=y                      # iptables nftables 后端（性能更高）
CONFIG_PACKAGE_xtables-legacy=y                    # 传统 xtables 工具（兼容旧脚本）
CONFIG_PACKAGE_xtables-nft=y                       # nftables 命令行工具（nft 命令）

# ======================== 全锥 NAT（游戏/联机必备） ========================
CONFIG_PACKAGE_kmod-ipt-fullconenat=y              # 全锥 NAT 内核模块（Full Cone NAT，改善 NAT 类型）
CONFIG_PACKAGE_iptables-mod-fullconenat=y          # iptables 插件（通过规则开启全锥 NAT）
CONFIG_PACKAGE_luci-app-fullconenat=y              # LuCI 配置界面（网页端一键开关）
