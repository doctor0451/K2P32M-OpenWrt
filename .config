CONFIG_TARGET_ramips=y                                                              # 目标平台：联发科 ramips 架构
CONFIG_TARGET_ramips_mt7621=y                                                       # 子架构：mt7621（K2P 使用的 SoC）
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y                                    # 具体设备：斐讯 K2P
CONFIG_TARGET_ROOTFS_PARTSIZE=32768                                                 # 根分区大小：32MB（适配 K2P 改版 32M Flash）

# USB 核心支持（必须）
CONFIG_USB_SUPPORT=y                                                                # 启用 USB 子系统总开关
CONFIG_PACKAGE_kmod-usb-core=y                                                      # USB 核心驱动（所有 USB 设备的基础）
CONFIG_PACKAGE_kmod-usb2=y                                                          # USB 2.0 控制器驱动（K2P 原生支持，USB3 向下兼容也需要）
CONFIG_PACKAGE_kmod-usb3=y                                                          # USB 3.0 支持（硬改 USB3 后必须开启）
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y                                                  # XHCI 标准主机控制器驱动（USB3 必需）
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                                                  # MediaTek MTK 平台的 XHCI 驱动（MT7621 专用）
CONFIG_PACKAGE_kmod-usb-storage=y                                                   # USB 存储设备支持（U盘/移动硬盘）
CONFIG_PACKAGE_kmod-usb-storage-uas=y                                               # UAS（USB Attached SCSI）协议，提升硬盘传输速度
CONFIG_PACKAGE_block-mount=y                                                        # 挂载管理工具（自动挂载/卸载）
CONFIG_PACKAGE_mount-utils=y                                                        # 挂载辅助工具（mount/umount）

# 文件系统支持（EXT4 + NTFS读写 + exFAT + UTF-8）
CONFIG_PACKAGE_kmod-fs-ext4=y                                                       # EXT4 文件系统驱动（Linux 原生，最稳定）
CONFIG_PACKAGE_kmod-fuse=y                                                          # FUSE 内核模块（ntfs-3g 依赖）
CONFIG_PACKAGE_ntfs-3g=y                                                            # NTFS 读写驱动（唯一推荐，可完全读写 NTFS）
CONFIG_PACKAGE_kmod-fs-exfat=y                                                      # exFAT 内核驱动
CONFIG_PACKAGE_exfat-fs=y                                                           # exFAT 文件系统工具
CONFIG_PACKAGE_exfatprogs=y                                                         # exFAT 格式化工具（mkfs.exfat）
CONFIG_PACKAGE_kmod-nls-utf8=y                                                      # UTF-8 编码支持（解决中文文件名乱码）
# CONFIG_PACKAGE_kmod-fs-ntfs is not set                                             # 关闭内核原生只读 NTFS（避免与 ntfs-3g 冲突）

# 系统基础 + 网页管理
#CONFIG_PACKAGE_luci=y                                                               # 已注释，不启用 LuCI 网页管理，会自动安装和它的依赖，加上更麻烦，要把依赖也写出来。
CONFIG_PACKAGE_kmod-reboot=y                                                        # 软重启驱动（解决 K2P 偶尔无法软重启的问题）

# ==================== Samba4 网络共享支持 ====================
CONFIG_PACKAGE_samba4-server=y                                                     # Samba4 核心服务（实现文件共享功能）
CONFIG_PACKAGE_luci-app-samba4=y                                                   # LuCI 网页控制插件（Web 界面管理共享）
CONFIG_PACKAGE_autosamba=y                                                         # 自动挂载 USB 设备并创建共享
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y                                             # Samba4 网页界面中文语言包
