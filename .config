# ========================== 基础设置 ==========================
CONFIG_TARGET_ramips=y                             # 目标平台：指定编译为联发科 ramips 硬件架构
CONFIG_TARGET_ramips_mt7621=y                      # 子架构：MT7621 芯片组（斐讯 K2P 专属 SoC）
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y   # 具体设备：精准适配斐讯 K2P 路由器型号
CONFIG_TARGET_ROOTFS_PARTSIZE=32512                # 根分区容量：32MB（适配 K2P 改版 32M 闪存，必须设置）

# ====================== USB 核心支持（必须） ======================
CONFIG_USB_SUPPORT=y                               # USB 总开关：启用系统 USB 子系统核心功能
CONFIG_PACKAGE_kmod-usb-core=y                     # USB 基础驱动：所有 USB 设备依赖的核心内核模块
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0 驱动：K2P 原生 USB 控制器必需，USB3 兼容依赖
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0 驱动：K2P 硬改 USB3 接口后必须开启
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y                 # XHCI 主控制器驱动：USB 3.0 协议标准核心驱动
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # MTK 专属 XHCI 驱动：MT7621 芯片 USB3 专用优化驱动
CONFIG_PACKAGE_kmod-usb-storage=y                  # USB 存储驱动：支持 U 盘、移动硬盘等存储设备
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # UAS 高速协议：大幅提升 USB 硬盘读写速度（替代传统 BOT）
CONFIG_PACKAGE_block-mount=y                       # 块设备挂载工具：系统自动挂载/卸载 USB 存储核心工具
#CONFIG_PACKAGE_mount-utils=y                       # 系统挂载工具：原生 mount/umount 命令（已由 block-mount 替代）

# ============= 文件系统支持（EXT4 + NTFS读写 + exFAT + UTF-8） =============
CONFIG_PACKAGE_kmod-fs-ext4=y                      # EXT4 文件系统：Linux 原生格式，稳定性/性能最优
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE 内核模块：用户空间文件系统，ntfs-3g 必需依赖
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS 读写驱动：完整支持 NTFS 格式读写，无权限/损坏问题
CONFIG_PACKAGE_kmod-fs-exfat=y                     # exFAT 内核驱动：支持大文件（>4G）的 exFAT 格式
CONFIG_PACKAGE_exfat-fs=y                          # exFAT 文件系统工具：exFAT 挂载与基础管理
CONFIG_PACKAGE_exfatprogs=y                        # exFAT 格式化工具：支持创建 mkfs.exfat 命令
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF-8 编码支持：解决 USB 设备中文文件名乱码问题
# CONFIG_PACKAGE_kmod-fs-ntfs is not set            # 禁用内核原生 NTFS：仅只读，易冲突，完全由 ntfs-3g 替代

# ======================= 系统基础 + 网页管理 =======================
#CONFIG_PACKAGE_luci=y                             # LuCI 网页管理：已注释关闭，不编译 Web 管理界面
CONFIG_PACKAGE_kmod-reboot=y                       # 软重启修复驱动：解决 K2P 原生系统偶尔无法软重启的 BUG

# ====================== Samba4 网络共享支持 ======================
CONFIG_PACKAGE_samba4-server=y                     # Samba4 服务端：实现局域网文件/打印机共享核心服务
CONFIG_PACKAGE_luci-app-samba4=y                   # Samba4 Web 插件：LuCI 界面可视化配置共享目录/权限
CONFIG_PACKAGE_autosamba=y                         # 自动共享工具：插入 USB 设备后自动挂载并创建 Samba 共享
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y            # Samba4 中文语言包：Web 界面显示中文，便于操作

# ======================== 防火墙内核模块 ========================
CONFIG_PACKAGE_kmod-ipt-core=y                     # iptables 核心模块：防火墙/NAT 功能基础内核模块
CONFIG_PACKAGE_kmod-ipt-conntrack=y                # 连接跟踪模块：防火墙状态检测、NAT 转发必需模块
CONFIG_PACKAGE_kmod-ipt-nat=y                      # NAT 转发模块：实现路由器上网、端口映射、UPnP 功能
CONFIG_PACKAGE_kmod-nft-compat=y                   # nftables 兼容层：让新内核兼容传统 iptables 规则
CONFIG_PACKAGE_iptables-nft=y                      # iptables 新后端：基于 nftables 实现的 iptables 命令工具
CONFIG_PACKAGE_xtables-legacy=y                    # 传统 iptables 工具：保留旧版命令，兼容老脚本/插件
CONFIG_PACKAGE_xtables-nft=y                       # nftables 工具集：新一代防火墙命令行工具

# ======================== 全锥 NAT（游戏/联机必备） ========================
CONFIG_PACKAGE_kmod-ipt-fullconenat=y              # 全锥 NAT 内核模块：底层实现高性能全锥 NAT
CONFIG_PACKAGE_iptables-mod-fullconenat=y          # 全锥 NAT 工具模块：iptables 调用全锥 NAT 功能依赖
CONFIG_PACKAGE_luci-app-fullconenat=y              # 全锥 NAT Web 插件：LuCI 界面一键开启/配置全锥 NAT
