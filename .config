# ========================== 基础设置 ==========================#
CONFIG_TARGET_ramips=y                             # 目标平台：联发科 ramips 架构
CONFIG_TARGET_ramips_mt7621=y                      # 子架构：mt7621（K2P 使用的 SoC）
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y   # 具体设备：斐讯 K2P
CONFIG_TARGET_ROOTFS_PARTSIZE=32128                # 根分区大小：32MB（适配 K2P 改版 32M Flash）

